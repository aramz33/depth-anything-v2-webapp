    <!-- api-spatial → groq-llama -->
    <mxCell id="e12" value="chat.completions.create" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="api-spatial" target="groq-llama" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- api-chat → groq-llama -->
    <mxCell id="e13" value="chat.completions.create" style="edgeStyle=orthogonalEdgeStyle;html=1;" edge="1" source="api-chat" target="groq-llama" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- api-vchat → groq-llama -->
    <mxCell id="e14" value="chat.completions.create + JSON mode" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;" edge="1" source="api-vchat" target="groq-llama" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- ARROWS — Responses back to Frontend (dashed) -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->

    <!-- predict → vc-capture (depth maps) -->
    <mxCell id="e15" value="colorized, grayscale URLs" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;strokeColor=#82b366;" edge="1" source="api-predict" target="vc-capture" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- transcribe → vc-mic -->
    <mxCell id="e16" value="{ text: transcript }" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;strokeColor=#82b366;" edge="1" source="api-transcribe" target="vc-mic" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- vision-chat → vc-recapture (needsCapture=true) -->
    <mxCell id="e17" value="{ response, needsCapture=true }" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;strokeColor=#d79b00;" edge="1" source="api-vchat" target="vc-recapture" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- vision-chat → vc-tts (final response) -->
    <mxCell id="e18" value="{ response, needsCapture=false }&#xa;→ TTS speak()" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;strokeColor=#82b366;" edge="1" source="api-vchat" target="vc-tts" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- chat → ip-chat -->
    <mxCell id="e19" value="messages[] mis à jour" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;strokeColor=#82b366;" edge="1" source="api-chat" target="ip-chat" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- analyze → ip-nav -->
    <mxCell id="e20" value="{ level, alert }" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;strokeColor=#82b366;" edge="1" source="api-analyze" target="ip-nav" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- spatial → ip-layout -->
    <mxCell id="e21" value="{ response }" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;strokeColor=#82b366;" edge="1" source="api-spatial" target="ip-layout" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

    <!-- predict → ip-upload -->
    <mxCell id="e22" value="{ original, colorized, grayscale, ms }" style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;strokeColor=#82b366;" edge="1" source="api-predict" target="ip-upload" parent="1">
      <mxGeometry relative="1" as="geometry" />
    </mxCell>

  </root>
</mxGraphModel>
